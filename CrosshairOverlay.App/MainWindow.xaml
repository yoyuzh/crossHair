<Window x:Class="CrosshairOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rendering="clr-namespace:CrosshairOverlay.App.Rendering"
        Title="外置准星"
        Width="760"
        Height="640"
        MinWidth="720"
        MinHeight="600"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#17202A" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5B6673" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="BorderBrush" Value="#D6DCE3" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#17202A" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#17202A" />
            <Setter Property="BorderBrush" Value="#17202A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <Style x:Key="SwatchButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="BorderBrush" Value="#B9C1CC" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="#D6DCE3" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#D6DCE3" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="外置准星" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="用于桌面和无边框窗口化游戏的屏幕中心标记工具。"
                           Foreground="#66717F"
                           Margin="0,4,0,0" />
            </StackPanel>
            <CheckBox x:Name="EnabledCheckBox"
                      Grid.Column="1"
                      Content="启用准星"
                      VerticalAlignment="Center"
                      FontSize="14"
                      Checked="OnSettingChanged"
                      Unchecked="OnSettingChanged" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,22,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Background="#FFFFFF" CornerRadius="10" BorderBrush="#E1E6EC" BorderThickness="1" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="方案" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ProfileComboBox"
                                      SelectionChanged="OnProfileSelectionChanged" />
                            <Button Grid.Column="2"
                                    Content="保存到方案"
                                    Click="OnSaveProfileClick" />
                        </Grid>

                        <TextBlock Style="{StaticResource LabelText}" Text="方案名称" />
                        <TextBox x:Name="ProfileNameTextBox"
                                 Margin="0,0,0,18"
                                 TextChanged="OnProfileNameChanged" />

                        <TextBlock Text="形状" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,14" />

                        <TextBlock Style="{StaticResource LabelText}" Text="样式" />
                        <ComboBox x:Name="StyleComboBox"
                                  Margin="0,0,0,18"
                                  SelectionChanged="OnSettingChanged" />

                        <TextBlock Text="颜色" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,14" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="ColorPreview"
                                    Width="46"
                                    Height="46"
                                    CornerRadius="8"
                                    BorderBrush="#B9C1CC"
                                    BorderThickness="1"
                                    Background="#00FF00" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource LabelText}" Text="十六进制" />
                                <TextBox x:Name="ColorTextBox"
                                         IsReadOnly="True"
                                         TextChanged="OnSettingChanged" />
                            </StackPanel>
                        </Grid>

                        <WrapPanel Margin="0,0,0,8">
                            <Button Style="{StaticResource SwatchButton}" Background="#00FF00" Tag="#00FF00" Click="OnPresetColorClick" />
                            <Button Style="{StaticResource SwatchButton}" Background="#FFFFFF" Tag="#FFFFFF" Click="OnPresetColorClick" />
                            <Button Style="{StaticResource SwatchButton}" Background="#FF3B30" Tag="#FF3B30" Click="OnPresetColorClick" />
                            <Button Style="{StaticResource SwatchButton}" Background="#FFCC00" Tag="#FFCC00" Click="OnPresetColorClick" />
                            <Button Style="{StaticResource SwatchButton}" Background="#00C7BE" Tag="#00C7BE" Click="OnPresetColorClick" />
                            <Button Style="{StaticResource SwatchButton}" Background="#0A84FF" Tag="#0A84FF" Click="OnPresetColorClick" />
                            <Button Style="{StaticResource SwatchButton}" Background="#BF5AF2" Tag="#BF5AF2" Click="OnPresetColorClick" />
                            <Button Style="{StaticResource SwatchButton}" Background="#FF2D55" Tag="#FF2D55" Click="OnPresetColorClick" />
                        </WrapPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="42" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="R" VerticalAlignment="Center" Foreground="#D43F3A" />
                            <Slider x:Name="RedSlider" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" ValueChanged="OnColorSliderChanged" />
                            <TextBlock x:Name="RedValueText" Grid.Column="2" TextAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Text="G" VerticalAlignment="Center" Foreground="#228A43" />
                            <Slider x:Name="GreenSlider" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" ValueChanged="OnColorSliderChanged" />
                            <TextBlock x:Name="GreenValueText" Grid.Row="1" Grid.Column="2" TextAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="2" Text="B" VerticalAlignment="Center" Foreground="#2563EB" />
                            <Slider x:Name="BlueSlider" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" ValueChanged="OnColorSliderChanged" />
                            <TextBlock x:Name="BlueValueText" Grid.Row="2" Grid.Column="2" TextAlignment="Right" VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="尺寸" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,14" />
                        <TextBlock Style="{StaticResource LabelText}" Text="长度" />
                        <Slider x:Name="SizeSlider" Minimum="1" Maximum="50" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSettingChanged" />

                        <TextBlock Style="{StaticResource LabelText}" Text="线宽" Margin="0,14,0,6" />
                        <Slider x:Name="ThicknessSlider" Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSettingChanged" />

                        <TextBlock Style="{StaticResource LabelText}" Text="间隙" Margin="0,14,0,6" />
                        <Slider x:Name="GapSlider" Minimum="0" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSettingChanged" />

                        <TextBlock Style="{StaticResource LabelText}" Text="透明度" Margin="0,14,0,6" />
                        <Slider x:Name="OpacitySlider" Minimum="0.1" Maximum="1" TickFrequency="0.05" ValueChanged="OnSettingChanged" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="X 偏移" />
                                <TextBox x:Name="OffsetXTextBox" TextChanged="OnSettingChanged" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource LabelText}" Text="Y 偏移" />
                                <TextBox x:Name="OffsetYTextBox" TextChanged="OnSettingChanged" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="快捷键" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,14" />
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource LabelText}" Text="显示/隐藏" VerticalAlignment="Center" />
                            <TextBox x:Name="ToggleHotkeyTextBox" Grid.Column="1" TextChanged="OnHotkeyChanged" />

                            <TextBlock Grid.Row="1" Style="{StaticResource LabelText}" Text="下一个方案" VerticalAlignment="Center" Margin="0,8,0,6" />
                            <TextBox x:Name="NextProfileHotkeyTextBox" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" TextChanged="OnHotkeyChanged" />

                            <TextBlock Grid.Row="2" Style="{StaticResource LabelText}" Text="方案 1" VerticalAlignment="Center" Margin="0,8,0,6" />
                            <TextBox x:Name="Profile1HotkeyTextBox" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" TextChanged="OnHotkeyChanged" />

                            <TextBlock Grid.Row="3" Style="{StaticResource LabelText}" Text="方案 2" VerticalAlignment="Center" Margin="0,8,0,6" />
                            <TextBox x:Name="Profile2HotkeyTextBox" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" TextChanged="OnHotkeyChanged" />

                            <TextBlock Grid.Row="4" Style="{StaticResource LabelText}" Text="方案 3" VerticalAlignment="Center" Margin="0,8,0,6" />
                            <TextBox x:Name="Profile3HotkeyTextBox" Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" TextChanged="OnHotkeyChanged" />

                            <TextBlock Grid.Row="5" Style="{StaticResource LabelText}" Text="方案 4" VerticalAlignment="Center" Margin="0,8,0,6" />
                            <TextBox x:Name="Profile4HotkeyTextBox" Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" TextChanged="OnHotkeyChanged" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Background="#17202A" CornerRadius="10" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="预览" Foreground="#FFFFFF" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="修改会立即应用到准星。"
                                   Foreground="#9BA7B4"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,22"
                            Background="#0B1016"
                            BorderBrush="#2C3642"
                            BorderThickness="1"
                            CornerRadius="10"
                            ClipToBounds="True">
                        <Grid>
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#121922" Offset="0" />
                                    <GradientStop Color="#05070A" Offset="1" />
                                </LinearGradientBrush>
                            </Grid.Background>
                            <rendering:CrosshairRenderer x:Name="PreviewRenderer" IgnoreEnabled="True" />
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2"
                               Text="不扫描进程，不注入，不发送输入。"
                               TextWrapping="Wrap"
                               Foreground="#9BA7B4" />
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存" Width="92" Margin="0,0,8,0" Style="{StaticResource PrimaryButton}" Click="OnSaveClick" />
            <Button Content="重置" Width="92" Margin="0,0,8,0" Click="OnResetClick" />
            <Button Content="退出" Width="92" Click="OnExitClick" />
        </StackPanel>
    </Grid>
</Window>
